{
  "kind": "collectionType",
  "collectionName": "tasks",
  "info": {
    "singularName": "task",
    "pluralName": "tasks",
    "displayName": "Card"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "taskName": {
      "type": "string"
    },
    "statue": {
      "type": "enumeration",
      "enum": [
        "À faire",
        "En cours",
        "Terminé",
        "space"
      ]
    },
    "date": {
      "type": "date"
    },
    "description": {
      "type": "text"
    },
    "column": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::column.column",
      "inversedBy": "cards"
    },
    "order": {
      "type": "integer"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "cards"
    }
  }
}
